MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/electromaison
JWT_SECRET=remplace-moi-par-une-longue-cle-secrete
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=production

# URLs publiques de production.
BACKEND_URL=https://votre-backend-render.onrender.com
FRONTEND_URL=https://votre-frontend.vercel.app

# Origines frontend autorisees par CORS. Pour plusieurs domaines, separe par des virgules.
CORS_ORIGINS=https://votre-frontend.vercel.app

# Optionnel: autorise les previews Vercel (*.vercel.app).
ALLOW_VERCEL_PREVIEWS=false

# Cloudinary (images produits).
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ton_api_key
CLOUDINARY_API_SECRET=ton_api_secret

# Configuration e-mail. Pour Gmail, utilisez un mot de passe d'application.
EMAIL_USER=votre-adresse@gmail.com
EMAIL_PASS=mot-de-passe-application-gmail
ADMIN_EMAIL=admin@exemple.com
NOTIFY_SIGNUP_EMAIL=admin@exemple.com
