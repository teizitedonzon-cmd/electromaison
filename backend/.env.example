MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/electromaison
JWT_SECRET=remplace-moi-par-une-longue-cle-secrete
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=development

# URL du frontend autorisee par CORS. Pour plusieurs domaines, separe par des virgules:
# CORS_ORIGINS=http://localhost:3001,https://votre-frontend.vercel.app
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001

# Optionnel: autorise les previews Vercel (*.vercel.app)
ALLOW_VERCEL_PREVIEWS=false

# ✅ AJOUTÉ : Cloudinary (images produits)
# Récupère ces 3 valeurs sur https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ton_api_key
CLOUDINARY_API_SECRET=ton_api_secret

# Configuration e-mail optionnelle.
# Pour Gmail, utilisez un mot de passe d'application.
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=
